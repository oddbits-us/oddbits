{
  "name": "@oddbits/imagebits",
  "version": "0.1.1",
  "description": "Image processing tools: resize, optimize, and convert formats",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oddbits-us/oddbits.git",
    "directory": "packages/imagebits"
  },
  "homepage": "https://github.com/oddbits-us/oddbits/tree/main/packages/imagebits",
  "bugs": {
    "url": "https://github.com/oddbits-us/oddbits/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "browser": "./dist/browser.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "imagebits": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.mjs",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.mjs"
    },
    "./node": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "test": "node --test --import tsx test/*.test.ts",
    "test:api": "node --test --import tsx test/node-api.test.ts",
    "test:cli": "npm run build && node --test --import tsx test/cli.test.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0 <23.0.0"
  },
  "keywords": [
    "oddbits",
    "image",
    "resize",
    "optimize",
    "webp",
    "convert"
  ],
  "author": "Dain Kennison",
  "license": "MIT",
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@oddbits/core": "workspace:*",
    "fflate": "^0.8.3",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
