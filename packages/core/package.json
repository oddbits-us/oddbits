{
  "name": "@oddbits/core",
  "version": "0.1.0",
  "description": "Core plugin system and utilities for oddbits ecosystem",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oddbits-us/oddbits.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/oddbits-us/oddbits/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/oddbits-us/oddbits/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser.mjs",
      "types": "./dist/browser.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18.0.0 <23.0.0"
  },
  "keywords": [
    "oddbits",
    "plugin",
    "core"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}

